# Local development — Vite proxies /api to localhost:8080 so this is only
# needed when running outside Docker or pointing at a remote backend.
VITE_API_URL=http://localhost:8080/api

# ── Vercel deployment ─────────────────────────────────────────────────────────
# Set this in Vercel dashboard → Project → Settings → Environment Variables
# VITE_API_URL=https://your-backend.up.railway.app/api
