# ─── Railway environment variables ───────────────────────────────────────────
# Set these in your Railway service → Variables tab.
# Never commit real values.

# Symfony
APP_ENV=prod
APP_SECRET=                        # openssl rand -hex 32

# PostgreSQL — Railway auto-fills this if you attach a Postgres plugin,
# otherwise paste the Neon / Supabase connection string.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# CORS — set to your Vercel frontend URL (no trailing slash)
# Supports regex: ^https://project-advisor\.vercel\.app$
# Or to allow both prod and preview URLs:
# ^https://project-advisor(-[a-z0-9]+)?\.vercel\.app$
CORS_ALLOW_ORIGIN=^https://your-project\.vercel\.app$
